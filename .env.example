# ──────────────────────────────────────────────────────────
# IDS Project — Environment Variables
# Copy this file to .env and fill in production values.
# ──────────────────────────────────────────────────────────

# ── Security (REQUIRED for production) ──────────────────
IDS_JWT_SECRET=replace-with-a-strong-random-secret
IDS_ADMIN_USERNAME=admin
IDS_ADMIN_PASSWORD=replace-with-a-strong-password
IDS_API_KEY=optional-api-key-for-legacy-auth

# ── CORS ────────────────────────────────────────────────
IDS_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8050

# ── Rate Limiting ───────────────────────────────────────
IDS_AUTH_RATE_LIMIT=10/minute

# ── Notifications ───────────────────────────────────────
IDS_TEAMS_WEBHOOK_URL=
IDS_GENERIC_WEBHOOK_URL=
IDS_SMTP_HOST=
IDS_SMTP_PORT=587
IDS_SMTP_USER=
IDS_SMTP_PASSWORD=
IDS_ALERT_EMAIL_TO=
IDS_ALERT_EMAIL_FROM=
IDS_NOTIFY_ON_SEVERITY_INCREASE=false

# ── Core Settings ───────────────────────────────────────
IDS_HOST_ID=
IDS_DB_PATH=data/ids.db
IDS_WINDOW_SECONDS=30
IDS_API_HOST=0.0.0.0
IDS_API_PORT=8000
IDS_MODEL_PATH=data/isolation_forest.joblib

# ── ML Tuning ───────────────────────────────────────────
IDS_MIN_TRAINING_SAMPLES=20
IDS_CONTAMINATION=0.05
IDS_RETRAIN_HOURS=24
IDS_CORRELATION_RULES_PATH=config/correlation_rules.yaml

# ── LLM (Ollama) ───────────────────────────────────────
IDS_OLLAMA_URL=http://localhost:11434
IDS_OLLAMA_MODEL=llama3

# ── Threat Intelligence ─────────────────────────────────
IDS_ABUSEIPDB_KEY=

# ── Data Retention ──────────────────────────────────────
IDS_RAW_EVENT_RETENTION_DAYS=7
IDS_FEATURE_WINDOW_RETENTION_DAYS=30

# ── JWT Token ───────────────────────────────────────────
IDS_JWT_EXPIRE_MINUTES=60

# ── Testing ─────────────────────────────────────────────
IDS_TESTING=false
IDS_SOAR_ENABLED=false
